generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Phase {
  PHASE_0   // Foundations & Pre-IB Review
  PHASE_1   // Algebra Fundamentals
  PHASE_2   // Functions & Equations
  PHASE_3   // Sequences, Series & Binomial
  PHASE_4   // Trigonometry
  PHASE_5   // Coordinate Geometry & Vectors
  PHASE_6   // Statistics & Probability
  PHASE_7   // Calculus I — Differentiation
  PHASE_8   // Calculus II — Integration & Applications
  PHASE_9   // Complex Numbers, Proof & Further Topics (HL)
  PHASE_10  // Exam Preparation & Review
}

enum ProblemType {
  MULTIPLE_CHOICE
  FREE_INPUT
  DRAG_AND_DROP
  GRAPHING
  PROOF_BUILDER
  WORKED_SOLUTION
}

enum ProblemPurpose {
  PRACTICE
  ASSIGNMENT
}

enum ClassRole {
  STUDENT
  TEACHER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ChallengeStatus {
  WAITING    // waiting for opponent
  ACTIVE     // in progress
  COMPLETED  // finished
  CANCELLED
}

// ── Users ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(STUDENT)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile StudentProfile?
  submissions    Submission[]
  progress       Progress[]
  badges         UserBadge[]

  teacherProfile TeacherProfile?
  createdLessons Lesson[]          @relation("CreatedBy")
  classes        ClassMembership[]

  sentFriendRequests     Friendship[] @relation("FriendRequester")
  receivedFriendRequests Friendship[] @relation("FriendReceiver")
  challengesCreated      Challenge[]  @relation("ChallengeCreator")
  challengesJoined       Challenge[]  @relation("ChallengeOpponent")
  challengeSubmissions   ChallengeSubmission[]
  coinTransactions       CoinTransaction[]
  conversations          Conversation[]
}

model StudentProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])
  currentPhase   Phase     @default(PHASE_0)
  xp             Int       @default(0)
  level          Int       @default(1)
  coins          Int       @default(0)
  streak         Int       @default(0)
  lastActiveDate DateTime?
  preferences    Json?
  activeClassId  String?
  activeClass    Class?    @relation(fields: [activeClassId], references: [id])
}

model TeacherProfile {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id])
  school String?
  bio    String?
}

// ── Curriculum ─────────────────────────────────────────

model Topic {
  id          String   @id @default(cuid())
  phase       Phase
  name        String
  slug        String   @unique
  description String?
  order       Int
  iconUrl     String?
  estimatedHours Float?
  ibSection      String?
  lessons        Lesson[]
  skills         Skill[]
  conversations  Conversation[]
}

model Lesson {
  id          String   @id @default(cuid())
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id])
  title       String
  slug        String   @unique
  description String?
  content     Json
  order       Int
  xpReward    Int      @default(10)
  problems      Problem[]
  assignments   ClassAssignment[]
  conversations Conversation[]
  sourceContent  Json?
  syllabusRef    String?
  estimatedHours Float?
  createdById    String?
  createdBy      User?    @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id            String         @id @default(cuid())
  topicId       String
  topic         Topic          @relation(fields: [topicId], references: [id])
  name          String
  slug          String         @unique
  description   String?
  prerequisites Skill[]        @relation("SkillPrereqs")
  dependents    Skill[]        @relation("SkillPrereqs")
  problems      ProblemSkill[]
  mastery       Progress[]
}

model Problem {
  id             String         @id @default(cuid())
  lessonId       String?
  lesson         Lesson?        @relation(fields: [lessonId], references: [id])
  type           ProblemType
  purpose        ProblemPurpose @default(PRACTICE)
  difficulty     Int
  content        Json
  commonMistakes Json?
  solution       Json?
  skills         ProblemSkill[]
  submissions    Submission[]
  explanations   Explanation[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ProblemSkill {
  problemId String
  skillId   String
  problem   Problem @relation(fields: [problemId], references: [id])
  skill     Skill   @relation(fields: [skillId], references: [id])

  @@id([problemId, skillId])
}

// ── Student progress ───────────────────────────────────

model Submission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id])
  answer     Json
  isCorrect  Boolean
  timeSpent  Int?
  aiAnalysis Json?
  createdAt  DateTime @default(now())
}

model Progress {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  skillId    String
  skill      Skill     @relation(fields: [skillId], references: [id])
  mastery    Float     @default(0)
  lastReview DateTime?
  nextReview DateTime?

  @@unique([userId, skillId])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeSlug String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeSlug])
}

// ── Classes ────────────────────────────────────────────

model Class {
  id              String            @id @default(cuid())
  name            String
  code            String            @unique
  phase           Phase             @default(PHASE_0)
  endPhase        Phase             @default(PHASE_10)
  members         ClassMembership[]
  assignments     ClassAssignment[]
  activeStudents  StudentProfile[]
  createdAt       DateTime          @default(now())
}

model ClassMembership {
  id      String    @id @default(cuid())
  classId String
  class   Class     @relation(fields: [classId], references: [id])
  userId  String
  user    User      @relation(fields: [userId], references: [id])
  role    ClassRole @default(STUDENT)

  @@unique([classId, userId])
}

model ClassAssignment {
  id         String    @id @default(cuid())
  classId    String
  class      Class     @relation(fields: [classId], references: [id])
  lessonId   String
  lesson     Lesson    @relation(fields: [lessonId], references: [id])
  problemIds    Json?     // Array of selected problem IDs; null = all problems
  questionCount Int?      // How many questions teacher requested
  passingGrade  Int?      // Minimum correct answers to pass; null = all questions
  studentIds    Json?     // Array of student user IDs; null = all students in class
  dueDate       DateTime?
  note       String?
  createdAt  DateTime  @default(now())

  @@unique([classId, lessonId])
}

// ── Social ────────────────────────────────────────────

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("FriendRequester", fields: [requesterId], references: [id])
  receiverId  String
  receiver    User             @relation("FriendReceiver", fields: [receiverId], references: [id])
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, receiverId])
}

// ── Challenges ────────────────────────────────────────

model Challenge {
  id          String          @id @default(cuid())
  creatorId   String
  creator     User            @relation("ChallengeCreator", fields: [creatorId], references: [id])
  opponentId  String?
  opponent    User?           @relation("ChallengeOpponent", fields: [opponentId], references: [id])
  status      ChallengeStatus @default(WAITING)
  topicId     String?
  difficulty  Int             @default(5)
  problemCount Int            @default(5)
  problems    Json            // Array of problem IDs
  timeLimit   Int             @default(300) // seconds
  creatorScore  Int           @default(0)
  opponentScore Int           @default(0)
  submissions ChallengeSubmission[]
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
}

model ChallengeSubmission {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  problemId   String
  isCorrect   Boolean
  timeSpent   Int?
  createdAt   DateTime  @default(now())

  @@unique([challengeId, userId, problemId])
}

// ── Coins / Wallet ──────────────────────────────────────

enum CoinReason {
  CORRECT_ANSWER
  ASSIGNMENT_COMPLETE
  TOPIC_COMPLETE
}

model CoinTransaction {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  amount    Int
  reason    CoinReason
  sourceId  String?    // lessonId, assignmentId, or topicId
  createdAt DateTime   @default(now())
}

// ── AI Tutor Conversations ──────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  lessonId  String?
  lesson    Lesson?   @relation(fields: [lessonId], references: [id])
  topicId   String?
  topic     Topic?    @relation(fields: [topicId], references: [id])
  title     String?
  summary   String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@unique([userId, lessonId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant" | "system"
  content        String       @db.Text
  metadata       Json?        // problemId context, token usage, tool calls
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Explanation {
  id             String   @id @default(cuid())
  conversationId String?
  problemId      String?
  problem        Problem? @relation(fields: [problemId], references: [id])
  title          String
  content        Json     // [{type:"step"|"latex"|"text"|"video", data:...}]
  animationUrl   String?
  manimCode      String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([problemId])
}
